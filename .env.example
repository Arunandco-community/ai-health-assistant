# ── Copy this to .env for local development ──
# On Railway, set these in the dashboard under Variables

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/ai_health_assistant?retryWrites=true&w=majority

# Server port (Railway sets this automatically)
PORT=3000

# Gmail SMTP for vaccine reminders
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
EMAIL_FROM_NAME=AI Health Assistant

# Python AI backend URL (set this after deploying the backend on Railway)
# Example: https://ai-health-backend-production.up.railway.app
AI_BACKEND_URL=http://localhost:8000
